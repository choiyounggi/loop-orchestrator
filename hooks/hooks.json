{
  "description": "loop-orchestrator hooks — dependency preflight (advisory, non-blocking) + verification-loop integrity gate.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/preflight.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/loop-gate.sh"
          }
        ]
      }
    ]
  }
}
